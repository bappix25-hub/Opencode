# Required
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
CHAT_ID=YOUR_CHAT_ID_HERE
HELIUS_API_KEY=YOUR_HELIUS_API_KEY_HERE

# Social APIs (Optional - bot works without)
TWITTER_BEARER_TOKEN=

# GitHub PAT (Optional - for auto data sync. Leave empty to disable)
GITHUB_PAT=
GITHUB_USER=bappix25-hub
GITHUB_REPO=Opencode

PUMPPORTAL_WS=wss://pumpportal.fun/api/data
RUGCHECK_URL=https://api.rugcheck.xyz/v1
DATA_FILE=./bot_data.json

# Thresholds
PUMP_MULTIPLIER=3.0
AI_THRESHOLD=0.65
MIN_LIQUIDITY=2000
MIN_VOLUME=300
MIN_MCAP=1000
MAX_MCAP=2000000

# Intervals
SCAN_INTERVAL=120
HISTORY_SCAN_INTERVAL=3600
GITHUB_SYNC_INTERVAL=21600
CLEANUP_INTERVAL=3600
BACKTEST_INTERVAL=604800

# Rate Limiting
DEXSCREENER_MAX_RETRIES=3
DEXSCREENER_BASE_DELAY=1.0

# Features
ENABLE_PRE_MIGRATION=true
ENABLE_HISTORY_SCAN=true
ENABLE_GITHUB_SYNC=true
ENABLE_SOCIAL_SIGNALS=true
ENABLE_AUTO_VERIFY=true

# Signal Filter
SIGNAL_MIN_THRESHOLD=0.60
GOLDEN_MIN_COUNT=5
BLACKLIST_MAX_FAILS=3

# Paper Trading
PAPER_TRADING=true
PAPER_TRADE_SOL=0.1
PAPER_TRADE_SOL_PER_BUY=0.01
PAPER_TRADE_MAX_POSITIONS=5
PAPER_TRADE_TIMEOUT_HOURS=3
